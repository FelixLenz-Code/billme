COMPOSE_PROJECT_NAME=billme-server-mode

# PostgreSQL
BILLME_POSTGRES_DB=billme
BILLME_POSTGRES_USER=billme
BILLME_POSTGRES_PASSWORD=change-me
BILLME_POSTGRES_PORT=5432
# Optional absolute host path for PostgreSQL data instead of the named volume.
# Useful on Podman setups where the container store lives on a filesystem that
# does not support PostgreSQL's permission changes on local volumes.
BILLME_POSTGRES_DATA_DIR=
# Optional container user override for PostgreSQL, for example 70:70 on
# rootless Podman when using a bind-mounted data directory prepared with
# `podman unshare chown -R 70:70 <dir>`.
BILLME_POSTGRES_RUN_AS=

# Fastify API
BILLME_API_PORT=3100
BILLME_PUBLIC_API_URL=http://localhost:3100
BILLME_SESSION_SECRET=replace-with-a-long-random-secret

# Browser shells
BILLME_WEB_PORT=4175
BILLME_WEB_PRO_PORT=4176

# Worker schedule tuning
WORKER_LOG_LEVEL=info
WORKER_RECURRING_INTERVAL_MS=900000
WORKER_DUNNING_INTERVAL_MS=900000
WORKER_EMAIL_QUEUE_INTERVAL_MS=60000
WORKER_PORTAL_SYNC_INTERVAL_MS=60000
WORKER_MAINTENANCE_INTERVAL_MS=86400000
WORKER_RUN_ONCE=0

# Optional outbound email secrets
SMTP_PASSWORD=
RESEND_API_KEY=
