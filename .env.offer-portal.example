# Offer Portal deployment config.
# Copy to .env.offer-portal and edit before the first start:
#   cp .env.offer-portal.example .env.offer-portal

# REQUIRED. Strong random key the desktop app sends as x-api-key when publishing.
# Generate one with: openssl rand -base64 32
OFFER_PORTAL_PUBLISH_API_KEY=

# Public URL clients reach the portal at, behind your reverse proxy.
# Used for generated links and to validate the origin of decision submissions.
OFFER_PORTAL_PUBLIC_BASE_URL=https://offers.example.com

# Fail closed by default. Leave as true for a public deployment.
OFFER_PORTAL_REQUIRE_PUBLISH_API_KEY=true

# Host port the container is published on (your reverse proxy forwards here).
OFFER_PORTAL_PORT=3001

# Interface the port binds to on the host. Keep 127.0.0.1 when the reverse proxy
# runs on the same host. Use 0.0.0.0 only if the proxy is remote and the network
# is firewalled, since this port serves plaintext HTTP.
OFFER_PORTAL_BIND_HOST=127.0.0.1
